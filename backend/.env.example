# ------------------------------------------------------------
# Atlas Backend - exemplo de configuracao
# Copie para .env e ajuste. NAO comite o .env real.
# ------------------------------------------------------------

# Armazenamento:
#   sqlite -> Windows/VPS (sem MongoDB)   <-- recomendado para o VPS
#   mongo  -> Linux/Emergent (default)
ATLAS_STORE=sqlite
ATLAS_SQLITE_PATH=C:\Atlas\data\atlas.db

# --- Modo de operacao ---------------------------------------
# Defina MT5_BRIDGE_URL para ativar dados REAIS (mode:mt5).
# Deixe em branco/comentado para usar dados MOCK (preview).
MT5_BRIDGE_URL=http://127.0.0.1:8002
MT5_BRIDGE_TOKEN=cole_aqui_o_mesmo_BRIDGE_TOKEN_do_bridge

# Multi-conta (Dark Mimas) - alternativa ao par acima:
# MT5_BRIDGE_URLS=http://127.0.0.1:8002,http://127.0.0.1:8003
# MT5_BRIDGE_TOKENS=token1,token2

# --- Servir o dashboard React a partir do backend -----------
SERVE_FRONTEND=true
FRONTEND_BUILD=C:\Atlas\frontend\build

# --- CORS ---------------------------------------------------
# '*' apenas para dev/testes. Restrinja antes de qualquer exposicao publica.
CORS_ORIGINS=*

# --- Mongo (apenas se ATLAS_STORE=mongo) --------------------
# MONGO_URL=mongodb://localhost:27017
# DB_NAME=atlas
