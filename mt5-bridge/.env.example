# MT5 broker credentials (the account the terminal is logged into)
MT5_LOGIN=12345678
MT5_PASSWORD=replace_me
MT5_SERVER=YourBroker-Server

# Optional: full path to terminal64.exe (only if you have multiple installations)
# MT5_TERMINAL_PATH=C:\Program Files\YourBroker MT5\terminal64.exe

# Generate with: python -c "import secrets;print(secrets.token_urlsafe(32))"
BRIDGE_TOKEN=replace_with_random_token

# Bridge HTTP
BRIDGE_HOST=0.0.0.0
BRIDGE_PORT=8002

# Recorder
SNAPSHOT_INTERVAL_SECONDS=10
SQLITE_PATH=bridge_data.db

LOG_LEVEL=INFO
